---
import AuthLayout from "../../layouts/AuthLayout.astro";
import { defaultLocale, t } from "../../lib/i18n";
import AuthEntry from "../../components/AuthEntry";
import AuthRedirect from "../../components/AuthRedirect";
---
<AuthLayout titleKey="auth.login.title">
  <AuthRedirect client:load />
  <section class="glass w-full max-w-md rounded-lg p-6">
    <p class="subtle-label" data-i18n="auth.login.eyebrow">{t(defaultLocale, "auth.login.eyebrow")}</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white" data-i18n="auth.login.heading">{t(defaultLocale, "auth.login.heading")}</h1>
    <p class="mt-3 text-sm leading-6 text-zinc-400" data-i18n="auth.login.copy">{t(defaultLocale, "auth.login.copy")}</p>
    <AuthEntry mode="login" client:load />
    <a class="mt-5 inline-flex text-sm text-zinc-400 hover:text-white" href="/auth/register" data-i18n="auth.login.needAccount">{t(defaultLocale, "auth.login.needAccount")}</a>
  </section>
</AuthLayout>
