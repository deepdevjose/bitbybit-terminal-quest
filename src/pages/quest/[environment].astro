---
import AppLayout from "../../layouts/AppLayout.astro";
import { environments } from "../../lib/curriculum";
import { defaultLocale, t, type TranslationKey } from "../../lib/i18n";
import AuthGate from "../../components/AuthGate";

export const prerender = true;

export function getStaticPaths() {
  return environments.map((environment) => ({ params: { environment: environment.slug }, props: { environment } }));
}

const { environment } = Astro.props;
const envNameKey = `environment.${environment.id}.name` as TranslationKey;
const envDescKey = `environment.${environment.id}.description` as TranslationKey;
const levelTitleKey = (levelId: number) => `level.${environment.id}.${levelId}.title` as TranslationKey;
---
<AppLayout titleKey={envNameKey}>
  <AuthGate mode="ready" client:load>
  <main class="mx-auto max-w-6xl px-6 pb-16 pt-8">
    <header class="mb-8">
      <p class="subtle-label" data-i18n="quest.eyebrow">{t(defaultLocale, "quest.eyebrow")}</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white md:text-6xl" data-i18n={envNameKey}>{t(defaultLocale, envNameKey)}</h1>
      <p class="mt-5 max-w-2xl text-zinc-400" data-i18n={envDescKey}>{t(defaultLocale, envDescKey)}</p>
    </header>
    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {environment.levels.map((level) => (
        <a class={`glass block rounded-lg p-5 transition ${level.missions.length ? "hover:-translate-y-0.5 hover:bg-white/[0.065]" : "opacity-60"}`} href={`/quest/${environment.slug}/level/${level.id}`}>
          <div class="flex items-start justify-between gap-4">
            <h2 class="text-xl font-semibold text-white"><span data-i18n="common.level">{t(defaultLocale, "common.level")}</span> {level.id}</h2>
            <span class="rounded-md border border-white/10 bg-white/5 px-2 py-1 text-xs text-zinc-400" data-i18n={level.missions.length ? "common.playable" : "common.planned"}>{t(defaultLocale, level.missions.length ? "common.playable" : "common.planned")}</span>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-white" data-i18n={levelTitleKey(level.id)}>{t(defaultLocale, levelTitleKey(level.id))}</h3>
          <p class="mt-3 min-h-20 text-sm leading-6 text-zinc-400" data-i18n={level.missions.length ? "level.playableDescription" : "level.placeholderDescription"}>{t(defaultLocale, level.missions.length ? "level.playableDescription" : "level.placeholderDescription")}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {level.commands.slice(0, 5).map((command) => <code class="rounded-md bg-zinc-950 px-2 py-1 text-xs text-zinc-400">{command}</code>)}
          </div>
        </a>
      ))}
    </section>
  </main>
  </AuthGate>
</AppLayout>
