---
import AppLayout from "../../layouts/AppLayout.astro";
import EnvironmentChooser from "../../components/EnvironmentChooser";
import { defaultLocale, t } from "../../lib/i18n";
import AuthGate from "../../components/AuthGate";
---
<AppLayout titleKey="onboarding.environment.title">
  <AuthGate mode="environment" client:load>
    <header class="mx-auto max-w-5xl px-6 pb-8 pt-10">
      <p class="subtle-label" data-i18n="onboarding.environment.eyebrow">{t(defaultLocale, "onboarding.environment.eyebrow")}</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-white md:text-6xl" data-i18n="onboarding.environment.heading">{t(defaultLocale, "onboarding.environment.heading")}</h1>
      <p class="mt-5 max-w-2xl text-zinc-400" data-i18n="onboarding.environment.copy">{t(defaultLocale, "onboarding.environment.copy")}</p>
    </header>
    <EnvironmentChooser client:load />
  </AuthGate>
</AppLayout>
